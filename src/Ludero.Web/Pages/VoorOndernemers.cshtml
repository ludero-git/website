@page "/voor-ondernemers"
@model VoorOndernemersModel
@{
    ViewData["Title"] = "Voor Ondernemers";
    ViewData["Description"] = "Intelligente energiesturing voor bedrijven die willen groeien zonder te wachten op netuitbreiding.";
}

<div class="page-header">
  <span class="label">EMS voor ondernemers</span>
  <h1>Meer doen met je<br/>bestaande aansluiting</h1>
  <p>Intelligente energiesturing voor bedrijven die willen groeien zonder te wachten op netuitbreiding.</p>
  <a class="btn btn-green" asp-page="/Contact">Ja, geef mij regie over mijn energie!</a>
</div>

<section class="features-list-section">
  <div class="section-inner">
    <div class="features-list-header">
      <div class="section-label">Wat Ludero EMS voor je doet</div>
      <h2 class="section-title">Zeven redenen om nu te starten</h2>
    </div>
    <div class="features-list-grid">

      <div class="feature-item">
        <div class="feature-item-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        </div>
        <div class="feature-item-text">
          <h3>✔ Piekbeheer &amp; loadbalancing</h3>
          <p>Voorkom overschrijding van je gecontracteerd vermogen en minimaliseer capaciteits- en piekkosten.</p>
        </div>
      </div>

      <div class="feature-item">
        <div class="feature-item-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/></svg>
        </div>
        <div class="feature-item-text">
          <h3>✔ Intelligente sturing van alle assets</h3>
          <p>Het systeem optimaliseert continu en automatisch de beste inzet van laden, ontladen, verwarmen of terugleveren.</p>
        </div>
      </div>

      <div class="feature-item">
        <div class="feature-item-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        </div>
        <div class="feature-item-text">
          <h3>✔ Meer doen met je bestaande aansluiting</h3>
          <p>Door intelligent te sturen is verzwaring vaak nog niet direct nodig. Je behoudt bedrijfscontinuïteit en groeit tóch door.</p>
        </div>
      </div>

      <div class="feature-item">
        <div class="feature-item-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
        </div>
        <div class="feature-item-text">
          <h3>✔ Altijd inzicht</h3>
          <p>Een helder dashboard toont je verbruik, opwek, prijsontwikkelingen, capaciteit en status van al je installaties.</p>
        </div>
      </div>

      <div class="feature-item">
        <div class="feature-item-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div class="feature-item-text">
          <h3>✔ Local-first veiligheid</h3>
          <p>De intelligente Ludero-controller stuurt bij voorkeur alles lokaal aan, en functioneert zelfs bij internetstoringen.</p>
        </div>
      </div>

      <div class="feature-item">
        <div class="feature-item-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        </div>
        <div class="feature-item-text">
          <h3>✔ Vendor onafhankelijk</h3>
          <p>Werkt met vrijwel alle gangbare merken laadpalen, omvormers, batterijen en warmtepompen.</p>
        </div>
      </div>

      <div class="feature-item" style="grid-column: 1 / -1; max-width: 480px;">
        <div class="feature-item-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
        </div>
        <div class="feature-item-text">
          <h3>✔ Schaalbaar</h3>
          <p>Het systeem groeit mee met je installatie en toekomstige uitbreidingen.</p>
        </div>
      </div>

    </div>

    <div style="margin-top:3rem; padding:2rem; background:var(--yellow); border-radius:14px; display:flex; align-items:center; justify-content:space-between; gap:2rem; flex-wrap:wrap;">
      <div>
        <div style="font-weight:700; font-size:1.05rem; color:var(--text)">Download onze factsheet</div>
        <div style="font-size:0.88rem; color:#555; margin-top:0.25rem">Ontvang alle technische details — laat je e-mail en telefoonnummer achter.</div>
      </div>
      <button class="btn btn-green" onclick="openModal('modal-factsheet')" type="button">Download onze factsheet</button>
    </div>
  </div>
</section>

<section class="cta-banner">
  <div class="section-inner" style="max-width:700px">
    <h2>Klaar om je energie slim te sturen?</h2>
    <a class="btn btn-primary" asp-page="/Contact">Neem contact op</a>
  </div>
</section>
