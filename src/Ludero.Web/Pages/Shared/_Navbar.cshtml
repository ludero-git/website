@{
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? string.Empty;
}

<nav class="navbar" id="navbar">
  <a class="logo" asp-page="/Index">
    <svg class="logo-icon" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <linearGradient id="g1" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#1a5f7a"/>
          <stop offset="50%" stop-color="#2d9e7a"/>
          <stop offset="100%" stop-color="#4dbf8a"/>
        </linearGradient>
        <linearGradient id="g2" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="#e8bb5e"/>
          <stop offset="100%" stop-color="#c89a3a"/>
        </linearGradient>
      </defs>
      <path d="M24 4C15 4 8 11 8 20C8 29 15 36 24 36C33 36 40 29 40 20" stroke="url(#g1)" stroke-width="5" fill="none" stroke-linecap="round"/>
      <path d="M24 12C19 12 15 16 15 21C15 26 19 30 24 30C29 30 33 26 33 21" stroke="url(#g1)" stroke-width="4" fill="none" stroke-linecap="round" opacity="0.7"/>
      <path d="M8 20C8 29 15 38 24 40C30 41 35 38 38 34" stroke="url(#g2)" stroke-width="4.5" fill="none" stroke-linecap="round"/>
    </svg>
    <div class="logo-text">
      <span class="brand">ludero</span>
      <span class="tagline">mastering your energy</span>
    </div>
  </a>

  <ul class="nav-links" id="navLinks">
    <li>
      <a asp-page="/Index" class="@(currentPage == "/Index" ? "active" : "")">Home</a>
    </li>
    <li>
      <a asp-page="/VoorOndernemers" class="@(currentPage == "/VoorOndernemers" ? "active" : "")">Voor Ondernemers</a>
    </li>
    <li>
      <a asp-page="/VoorEnergyHubs" class="@(currentPage == "/VoorEnergyHubs" ? "active" : "")">Voor Energy Hubs</a>
    </li>
    <li>
      <a asp-page="/Contact" class="nav-cta @(currentPage == "/Contact" ? "active" : "")">Contact</a>
    </li>
  </ul>

  <div class="hamburger" id="hamburger" onclick="toggleMobileNav()">
    <span></span><span></span><span></span>
  </div>
</nav>
