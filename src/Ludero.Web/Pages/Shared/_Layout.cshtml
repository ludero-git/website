<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>@(ViewData["Title"] != null ? ViewData["Title"] + " – " : "")Ludero – Mastering Your Energy</title>
  <meta name="description" content="@(ViewData["Description"] ?? "Ludero EMS geeft ondernemers en energiecoöperaties lokale regie over hun energie-infrastructuur. Slim sturen, kosten besparen, doorgroeien.")" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,300;0,600;0,700;0,900;1,300;1,600&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
  <partial name="_Navbar" />

  @RenderBody()

  <partial name="_Footer" />

  <partial name="_ModalFactsheet" />
  <partial name="_ModalCookies" />
  <partial name="_ModalPrivacy" />
  <partial name="_ModalAV" />

  <script src="~/js/site.js" asp-append-version="true"></script>
</body>
</html>
